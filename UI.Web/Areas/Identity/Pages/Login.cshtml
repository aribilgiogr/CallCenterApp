@page
@model LoginModel

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh; background: #f0f2f5;">
    <div class="card shadow-sm" style="width: 100%; max-width: 400px; border: none; border-radius: 16px;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <h4 class="fw-semibold mb-1">Hoş Geldiniz</h4>
                <p class="text-muted mb-0" style="font-size: 0.875rem;">Hesabınıza giriş yapın</p>
            </div>

            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <a href="#" class="text-decoration-none small">Şifremi unuttum?</a>
                    </div>
                    <input asp-for="Input.Password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label small"></label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Giriş Yap</button>

                <p class="text-center text-muted mt-4 mb-0 small">
                    Hesabınız yok mu? <a asp-action="Register" class="text-decoration-none">Kayıt olun</a>
                </p>
            </form>

        </div>
    </div>
</div>